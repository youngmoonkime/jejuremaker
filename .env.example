# Supabase Configuration (Required — these are public/safe keys)
VITE_SUPABASE_URL=https://jbkfsvinitavzyflcuwg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- LOCAL DEVELOPMENT ONLY ---
# These keys are ONLY needed for local development.
# In production, they are handled by Supabase Edge Functions (server-side secrets).
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_TRIPO_API_KEY=your_tripo_api_key_here

# Cloudflare R2 Configuration (Only for local dev — production uses Edge Functions)
VITE_R2_ACCOUNT_ID=your_r2_account_id_here
VITE_R2_ACCESS_KEY_ID=your_r2_access_key_id_here
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
VITE_R2_BUCKET_NAME=jeju-remaker-assets
VITE_R2_PUBLIC_DOMAIN=https://pub-b7d22eda2a2840a99f84fad5136127e0.r2.dev
